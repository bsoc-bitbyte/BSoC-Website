rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /userStats-2024/{document=**} {
      allow read: if true; 
      allow write: if request.auth != null; 
    }
    match /userStats-2025/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}