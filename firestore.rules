rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if
          request.time < timestamp.date(2026,7,7);
          }
    match /dashboard-2026/{document} {
      allow read, write: if request.auth!=null;
          
    }
    match /userStats-2026/{document} {
      allow read, write: if request.auth!=null;
          
    }
  }
}